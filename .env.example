# ──────────────────────────────────────────────────────────────
# Witness Oracle Ecosystem — L1 Price & Asset Witness
# ──────────────────────────────────────────────────────────────

# --- Telegram Connectivity ---
TELEGRAM_BOT_TOKEN="YOUR_BOT_TOKEN"
TELEGRAM_CHAT_ID="YOUR_CHAT_ID"
TELEGRAM_ENABLED=true

# --- Bitcoin L1 Connectivity ---
# Multi-RPC Public Endpoints (Supports getblock verbosity=0)
BITCOIN_RPC_URLS=https://bitcoin-rpc.publicnode.com

# --- Witness BTC Price Oracle ---
PRICE_WINDOW_BLOCKS=36
MIN_SAMPLE_ENTROPY=10000          # Min TXs in window for valid statistical extraction
MAX_EXPANSION_BLOCKS=144          # Max history expansion if entropy is low
POLL_INTERVAL_SEC=30

# --- Binohash Integrity Guard ---
BINOHASH_DIFFICULTY=2             # Number of leading hex zeros (W parameter)

# --- Witness Asset Oracle ---
ASSET_POLL_INTERVAL_SEC=60
TARGET_ASSET_TICKER=DOG           # Ticker for the specific asset_price_state.json
# Note: Global Scan ranks ALL BRC-20 and Runes by volume automatically.
